{
  "name": "range",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Range — Codex-first development harness for simulation-heavy software",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k -n server,web -c green,blue \"bun run dev:server\" \"bun run dev:web\"",
    "dev:server": "bun run --hot server/index.ts",
    "dev:web": "vite",
    "build": "tsc -b && vite build",
    "build:server": "bun build server/index.ts --outdir dist/server --target bun",
    "start": "RANGE_ENV=production bun run server/index.ts",
    "typecheck": "tsc -b --noEmit",
    "lint": "echo 'lint not configured yet'"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.11.2",
    "hono": "^4.6.14",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "yaml": "^2.9.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@tailwindcss/vite": "^4.0.0",
    "concurrently": "^9.1.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
